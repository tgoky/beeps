# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/beeps"
DIRECT_URL="postgresql://user:password@host:5432/beeps"

# ─── Supabase Auth ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Stripe (International Payments — USD/GBP/EUR/etc.) ──────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook secret from: https://dashboard.stripe.com/webhooks
# Endpoint: POST /api/payments/webhook/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Paystack (Nigeria NGN & Ghana GHS) ──────────────────────────────────────
# Get from: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_..."

# Webhook IP whitelist: 52.31.139.75, 52.49.173.169, 52.214.14.220
# Endpoint: POST /api/payments/webhook/paystack
